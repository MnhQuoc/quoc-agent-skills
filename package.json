{
  "name": "quoc-agent-skills",
  "private": true,
  "version": "1.0.0",
  "description": "Personal agent skills + local mini skills.sh-style browsing page",
  "scripts": {
    "generate": "node scripts/generate-manifest.js",
    "start": "npm run generate && node server.js",
    "api": "node api/server.js",
    "app": "npm run app:install && cd app && npm run dev",
    "app:install": "cd app && npm install",
    "migrate": "node scripts/migrate-to-mongo.js",
    "sync-cursor": "node scripts/sync-to-cursor.js"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "gpt-tokenizer": "^3.4.0",
    "mongoose": "^9.7.4"
  }
}
