MONGODB_URI=mongodb://localhost:27017/quoc-agent-skills
API_PORT=4322

# Cursor SDK — bắt buộc để chạy skill workflow (web hub)
# User API Key từ dashboard — bắt đầu bằng crsr_ (KHÔNG thêm prefix cursor_)
CURSOR_API_KEY=crsr_...
# CURSOR_MODEL=composer-2.5

# Cookie session Cursor Dashboard — tùy chọn (API tự đọc từ state.vscdb nếu bỏ trống)
# Lấy thủ công: cursor.com → DevTools → Cookies → WorkosCursorSessionToken (dạng sub::jwt)
# Hoặc chạy: npm run extract-session
# CURSOR_SESSION_TOKEN=eyJhbGci...
# CURSOR_SESSION_COOKIE=WorkosCursorSessionToken=user_xxx%3A%3AeyJhbGci...
